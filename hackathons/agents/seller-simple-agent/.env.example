# Nevermined (required)
NVM_API_KEY=sandbox:your-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=your-plan-id
NVM_AGENT_ID=your-agent-id          # required for A2A mode

# LLM - OpenAI (for local dev with agent.py)
OPENAI_API_KEY=sk-your-key
MODEL_ID=gpt-4o-mini

# LLM - Bedrock (for AgentCore with agent_agentcore.py)
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Server
PORT=3000

# A2A Server (for agent-a2a mode)
A2A_PORT=9000

# Buyer registration URL (for auto-registration with buyer)
BUYER_URL=

# Observability (A2A mode only) - routes LLM calls through Nevermined proxy
OBSERVABILITY_ENABLED=false

# AgentCore deployment (for agent-a2a-agentcore mode)
# PORT=8080                    # Set by AgentCore runtime
# AGENT_URL=https://your-agent.agentcore.aws  # AgentCore public URL
